{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{let p=q.url==='/'?'/index.html':q.url;if(!require('path').extname(p))p+='/index.html';let f=require('path').join('.',p);require('fs').readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{let t={'html':'text/html','css':'text/css','js':'application/javascript','json':'application/json','svg':'image/svg+xml'}[require('path').extname(f).slice(1)]||'text/plain';r.writeHead(200,{'Content-Type':t+';charset=utf-8'});r.end(d);}});}).listen(3000,()=>console.log('Server running on port 3000'))"],
      "port": 3000
    }
  ]
}
